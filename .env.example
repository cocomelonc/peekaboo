# peekaboo .env
# Copy to .env, fill in real values, restart the app.
# Safe to commit; secrets live in .env (gitignored).

# Optional for non-browser clients. Same-origin dashboard writes remain local.
PEEKABOO_API_TOKEN=

# -- Knowledge base sources -------------------------------------------
# Path to the meow repo on this machine. Used by worker.py (tag) and the
# chatbot's full-code reader. Leave blank to use stored absolute paths as-is.
MEOW_ROOT=/path/to/meow

# Path to the Jekyll blog's _posts directory. Used by the indexer
# (worker.py scan) to build library_cache.json from local .markdown files.
BLOG_POSTS_ROOT=/path/to/cocomelonc.github.io/_posts

# -- AI: Ollama -------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_EMBED_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.15
OLLAMA_TOP_P=0.75
OLLAMA_NUM_THREAD=8
OLLAMA_CONTEXT_POSTS=2
OLLAMA_CONTEXT_POSTS_TECHNICAL=2
OLLAMA_NUM_CTX=3072
OLLAMA_NUM_PREDICT=280
OLLAMA_MAX_SNIPPET_LINES=12
OLLAMA_FALLBACK_SNIPPETS=1
OLLAMA_KEEP_ALIVE=30m

# -- Threat Intel: Malpedia -------------------------------------------
MALPEDIA_API_TOKEN=<your-token-here>

# -- Threat Intel: VirusTotal -----------------------------------------
VT_API_KEY=<your-api-key-here>
VT_FILE_ID=<value>

# -- Stealer/C2: Telegram ---------------------------------------------
TELEGRAM_BOT_TOKEN=<your-token-here>
TELEGRAM_CHAT_ID=<value>

# -- Stealer/C2: GitHub -----------------------------------------------
GITHUB_TOKEN=<your-token-here>
GITHUB_REPO_OWNER=<value>
GITHUB_REPO_NAME=<value>
GITHUB_ISSUE_NUMBER=<value>

# -- Stealer/C2: Bitbucket --------------------------------------------
BITBUCKET_TOKEN_BASE64=<your-token-here>
BITBUCKET_WORKSPACE=<value>
BITBUCKET_REPO=<value>

# -- Stealer/C2: Slack ------------------------------------------------
SLACK_WEBHOOK_URL=<https://hooks.slack.com/services/...>

# -- Stealer/C2: Azure ------------------------------------------------
AZURE_ORG=<value>
AZURE_PROJECT=<value>
AZURE_PAT=<your-pat-here>

# -- Stealer/C2: Angelcam ---------------------------------------------
ANGELCAM_API_KEY=<your-api-key-here>

# -- APT Pipeline -----------------------------------------------------
APT_PIPELINE_COMPILE_EACH=True
APT_PIPELINE_MAX_STAGES=12
APT_PIPELINE_OLLAMA_NARRATION=False
APT_PIPELINE_OLLAMA_BASE_URL=http://localhost:11434
APT_PIPELINE_OLLAMA_MODEL=qwen3:0.6b
